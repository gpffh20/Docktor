FROM node:20-alpine

WORKDIR /app

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

COPY node-app/package*.json ./
RUN npm install

COPY --chown=appuser:appgroup node-app/. .
USER appuser

HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD node -e "process.exit(0)"

CMD ["node", "app.js"]
